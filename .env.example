# ============================================================================
# APN Hub — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your Supabase project values.
#
# IMPORTANT: The app is designed to run WITHOUT these set. When Supabase env
# vars are missing, APN Hub automatically falls back to built-in seed data
# (read-only) so you can preview the full UI immediately. Set these to connect
# to a real database and enable submissions, prayer counts, and the admin area.
# ============================================================================

# --- Supabase (public — safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase service role (SERVER ONLY — never expose to the browser) ---
# Used by API routes + admin dashboard to write/approve content.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin access ---
# Comma-separated list of admin email addresses allowed into /admin.
# These should also exist in the `admin_users` table.
ADMIN_EMAILS=you@example.com

# --- Site config ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
