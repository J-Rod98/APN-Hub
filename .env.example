# APN Hub's public catalog works without environment variables.
# The suggestion handler uses this Formspree endpoint by default; set it only
# when routing production suggestions to a different Formspree form.
FORMSPREE_SUGGESTION_ENDPOINT=https://formspree.io/f/mjgqjoek

# Optional Cloudflare Turnstile. Configure both values together to require a
# final-submission verification challenge on /submit.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
